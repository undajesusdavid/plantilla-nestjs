{
  "type": "postgres",
  "url": "${process.env.DATABASE_URL}",
  "entities": [
    "src/**/*.model.ts"
  ],
  "migrations": [
    "src/database/migrations/*.ts"
  ],
  "subscribers": [
    "src/database/subscribers/*.ts"
  ],
  "cli": {
    "entitiesDir": "src",
    "migrationsDir": "src/database/migrations",
    "subscribersDir": "src/database/subscribers"
  },
  "synchronize": false,
  "logging": true,
  "ssl": {
    "rejectUnauthorized": false
  }
}
