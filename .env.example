# JWT Configuration
# CRITICAL: Generate a secure random string of at least 32 characters
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secure_secret_with_at_least_32_characters_here
JWT_EXPIRES_IN=24h

# Database Configuration
# PostgreSQL Connection String
DATABASE_URL=postgresql://user:password@localhost:5432/plantilla_nestjs

# Optional: Disable auto-sync in production (use migrations instead)
DB_SYNC=false

# Application
NODE_ENV=development
PORT=3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
